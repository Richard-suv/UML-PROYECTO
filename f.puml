@startuml

skinparam componentStyle rectangle
skinparam backgroundColor white

skinparam component {
BackgroundColor #EBF5FB
BorderColor #1B4F72
FontColor black
}

skinparam database {
BackgroundColor #FDEDEC
BorderColor #922B21
}

skinparam node {
BackgroundColor #E8F8F5
BorderColor #117864
}

title Diagrama de Componentes - RutaFlex

package "Cliente" {

[Landing Page] as Landing
[Mobile App] as Mobile

}

package "Backend Services" {

component "Servicio de Autenticación" as Auth
component "Trip Management Service" as Trip
component "Chat Service" as Chat
component "Servicio de Notificacion" as Notify
component "Servicio de Reputacición" as Reputation
component "History & Analytics Service" as Analytics

}

package "Persistence Layer" {

database "User Database" as UserDB
database "Trip Database" as TripDB
database "Chat Database" as ChatDB

}

package "External Services" {

component "Firebase Cloud Messaging" as Firebase
component "Google Maps API" as Maps
component "Email Verification Service" as EmailService

}

' =========================
' CLIENT CONNECTIONS
' =========================

Landing --> Auth : Registro/Login
Landing --> Mobile : Descargar App

Mobile --> Auth : Autenticación
Mobile --> Trip : Gestión de viajes
Mobile --> Chat : Mensajería
Mobile --> Notify : Notificaciones
Mobile --> Reputation : Calificaciones
Mobile --> Analytics : Historial y ahorro

' =========================
' BACKEND CONNECTIONS
' =========================

Auth --> UserDB : CRUD usuarios
Auth --> EmailService : Verificación correo

Trip --> TripDB : CRUD viajes
Trip --> Maps : Geolocalización

Chat --> ChatDB : Mensajes

Notify --> Firebase : Push notifications

Reputation --> UserDB : Reputación usuarios

Analytics --> TripDB : Historial viajes
Analytics --> UserDB : Datos usuario

' =========================
' INTERNAL COMMUNICATION
' =========================

Trip --> Notify : Eventos de viaje
Chat --> Notify : Nuevos mensajes
Reputation --> Analytics : Métricas

@enduml
