@startuml "Proceso de Dominio: Verificación de Credenciales"
skinparam SwimlaneTitleBackgroundColor #F5F5F5
skinparam ActivityBackgroundColor #E8F5E9
skinparam ActivityBorderColor #2E7D32
skinparam Arrow {
  Color #2E7D32
}

|Estudiante|
start
:Solicitar Registro en Plataforma;
:Ingresar Correo Institucional;

|Contexto Gestión de Usuarios|
:Analizar Dominio del Correo;

if (¿Es Correo Universitario Válido?) then (Sí)
  :Generar Token de Verificación Unico;
  :Disparar Evento: TokenDeValidaciónCreado;
  |Servicio de Mensajería Externo|
  :Despachar Correo con Enlace Seguro;
  |Estudiante|
  :Acceder al Enlace de Validación;
  |Contexto Gestión de Usuarios|
  :Mutar Estado: CredencialMarcadaComoVerificada;
  :Habilitar Acceso Completo al Ecosistema;
  stop
else (No)
  |Contexto Gestión de Usuarios|
  :Rechazar Solicitud de Registro;
  :Emitir Alerta de Restricción de Dominio;
  stop
endif
@enduml