@startuml "Business Case: RutaFlex - DDD Aligned"
left to right direction

actor "Estudiante Conductor" <<Domain Actor>> as Driver
actor "Estudiante Pasajero" <<Domain Actor>> as Passenger

rectangle "Capacidades del Dominio Principal" {
    usecase "Orquestar Viajes Compartidos\n(Core Domain)" as BUC1
    usecase "Ofrecer Itinerario de Ruta" as BUC2
    usecase "Adquirir Cupo de Viaje" as BUC3
    usecase "Sincronizar Coordinación de Trayecto" as BUC4
    usecase "Evaluar Reputación del Actor" as BUC5
    usecase "Monitorear Indicadores de Impacto\n(Ahorro y CO2)" as BUC7
}

Driver --> BUC1
Passenger --> BUC1

Driver --> BUC2
Passenger --> BUC3
Driver --> BUC4
Passenger --> BUC4

Driver --> BUC5
Passenger --> BUC5

Passenger --> BUC7
Driver --> BUC7

BUC2 --> BUC1 : <<include>>
BUC3 --> BUC1 : <<include>>
BUC4 --> BUC1 : <<include>>
BUC5 --> BUC1 : <<include>>
BUC7 --> BUC1 : <<include>>

skinparam usecase {
  BackgroundColor #E8F5E9
  BorderColor #2E7D32
}
skinparam actor {
  BackgroundColor #E8F5E9
  BorderColor #2E7D32
}
skinparam Arrow {
  Color #2E7D32
}
@enduml