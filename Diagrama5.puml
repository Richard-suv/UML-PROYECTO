@startuml
actor Pasajero
boundary "App RutaFlex" as App
control "AuthController" as Auth
control "ViajeController" as ViajeC
entity "ViajeService" as ViajeS
database "BD RutaFlex" as DB

Pasajero -> App : Ingresar correo y contraseña
App -> Auth : autenticar(correo, contraseña)
Auth -> DB : validarUsuario()
DB --> Auth : usuario válido
Auth --> App : sesión creada

Pasajero -> App : Buscar viajes
App -> ViajeC : buscarViajes(destino, hora)
ViajeC -> ViajeS : obtenerViajesFiltrados()
ViajeS -> DB : consultarViajes()
DB --> ViajeS : lista de viajes
ViajeS --> ViajeC : resultados
ViajeC --> App : mostrar listado

Pasajero -> App : Ver detalle de viaje
App -> ViajeC : obtenerDetalle(viajeId)
ViajeC -> ViajeS : detalleViaje(viajeId)
ViajeS -> DB : consultarDetalle()
DB --> ViajeS : detalle
ViajeS --> ViajeC : detalle
ViajeC --> App : mostrar detalle

Pasajero -> App : Abrir chat / calificar / ver historial
App --> Pasajero : Interacción disponible
@enduml