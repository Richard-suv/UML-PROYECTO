@startuml
title Contexto de Gestión de Viajes - Casos de Uso del Dominio

skinparam packageStyle rectangle

actor "Estudiante Pasajero" as Pasajero
actor "Estudiante Conductor" as Conductor

rectangle "Bounded Context: Gestión de Viajes" {
  usecase "Consultar Catálogo de Viajes por Destino" as UC1
  usecase "Filtrar Ofertas por Ventana Horaria" as UC2
  usecase "Inspeccionar Invariantes y Detalles del Viaje" as UC3
  usecase "Verificar Reputación de Actores Asociados" as UC4
  usecase "Establecer Canal de Comunicación Directo" as UC5
}

Pasajero --> UC1
Pasajero --> UC2
Pasajero --> UC3
Pasajero --> UC4
Pasajero --> UC5

Conductor --> UC4
Conductor --> UC5
@enduml