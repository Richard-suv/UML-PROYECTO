@startuml

title Diagrama de Caso de Uso de Negocio - RutaFlex

left to right direction
skinparam packageStyle rectangle

actor "Pasajero" as Pasajero
actor "Conductor" as Conductor

rectangle "Negocio RutaFlex:\nBuscar Viaje" {
  usecase "Buscar viajes\npor destino" as UC1
  usecase "Filtrar viajes\npor hora/destino" as UC2
  usecase "Ver detalles\ndel viaje" as UC3
  usecase "Seleccionar viaje" as UC4
  usecase "Contactar conductor" as UC5
  usecase "Compartir ubicación\nen tiempo real" as UC6
  usecase "Ver reputación\nantes de confirmar" as UC7
}

Pasajero --> UC1
Pasajero --> UC2
Pasajero --> UC3
Pasajero --> UC4
Pasajero --> UC5
Pasajero --> UC6
Pasajero --> UC7

Conductor --> UC6
Conductor --> UC7
@enduml
