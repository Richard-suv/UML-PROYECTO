@startuml
skinparam classAttributeIconSize 0

title Bounded Context - Seguridad e Historial

class Calificacion {
  +id: UUID
  +puntaje: int
  +comentario: String
  +fecha: DateTime
}

class HistorialViaje {
  +id: UUID
  +fechaRegistro: DateTime
  +descripcion: String
}

class Ahorro {
  +id: UUID
  +monto: Decimal
  +moneda: String
}

class CO2Ahorrado {
  +id: UUID
  +valor: Decimal
  +unidad: String
}

class ValidacionIdentidad {
  +id: UUID
  +estado: String
  +fechaValidacion: DateTime
}

HistorialViaje "1" o-- "0..*" Calificacion
HistorialViaje "1" o-- "0..*" Ahorro
HistorialViaje "1" o-- "0..*" CO2Ahorrado
ValidacionIdentidad --> HistorialViaje
@enduml