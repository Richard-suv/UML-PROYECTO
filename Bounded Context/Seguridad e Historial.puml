@startuml
skinparam handwritten false
skinparam monochrome false
skinparam packageStyle rect
skinparam shadowing false

title Bounded Context: Seguridad e Historial

package "Compartido" <<Rectangle>> {
    class UsuarioId << (V,#99FF99) Value Object >> {
        - valor: Long
    }
    class ViajeId << (V,#99FF99) Value Object >> {
        - valor: Long
    }
}

package "Agregado Calificacion" <<Rectangle>> {
    class Calificacion << (E,#FF7700) Aggregate Root >> {
        - id: CalificacionId
        - usuarioCalificadoId: UsuarioCalificadoId
        - puntaje: Puntaje
    }

    class CalificacionId << (V,#99FF99) Value Object >> {
        - valor: Long
    }

    class UsuarioCalificadoId << (V,#99FF99) Value Object >> {
        - valor: Long
    }

    class Puntaje << (V,#99FF99) Value Object >> {
        - valor: Integer
    }
}

package "Agregado Historial Viajes" <<Rectangle>> {
    class HistorialViajes << (E,#FF7700) Aggregate Root >> {
        - id: HistorialId
        - usuarioId: UsuarioId
        + registrarViajeCompletado(viajeId: ViajeId, ahorroMonto: Decimal, co2Kilogramos: Decimal)
    }

    class HistorialId << (V,#99FF99) Value Object >> {
        - valor: Long
    }

    class RegistroViaje << (E,#1199FF) Entity >> {
        - id: RegistroViajeId
        - viajeId: ViajeId
    }

    class RegistroViajeId << (V,#99FF99) Value Object >> {
        - valor: Long
    }

    class Ahorro << (E,#1199FF) Entity >> {
        - id: AhorroId
        - monto: Decimal
    }

    class AhorroId << (V,#99FF99) Value Object >> {
        - valor: Long
    }

    class AhorroCO2 << (E,#1199FF) Entity >> {
        - id: AhorroCO2Id
        - kilogramos: Decimal
    }

    class AhorroCO2Id << (V,#99FF99) Value Object >> {
        - valor: Long
    }
}

' Relaciones del Agregado Historial
HistorialViajes "1" *--> "*" RegistroViaje : contiene >
HistorialViajes "1" *--> "*" Ahorro : acumula >
HistorialViajes "1" *--> "*" AhorroCO2 : calcula >

' Vinculaciones externas usando IDs compartidos
Calificacion ..> UsuarioCalificadoId : evalúa a >
HistorialViajes ..> UsuarioId : pertenece a >
RegistroViaje ..> ViajeId : referencia a >

@enduml