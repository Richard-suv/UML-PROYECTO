@startuml
skinparam classAttributeIconSize 0

title Bounded Context - Gestión de Viajes

class Ruta {
  +id: UUID
  +origen: String
  +destino: String
  +horaSalida: DateTime
  +precioCompartido: Decimal
  +cuposDisponibles: int
  +estado: String
}

class Viaje {
  +id: UUID
  +fecha: Date
  +hora: Time
  +estado: String
}

class DetalleViaje {
  +id: UUID
  +puntoEncuentro: String
  +descripcion: String
}

class FiltroViaje {
  +hora: String
  +destino: String
}

class ReservaViaje {
  +id: UUID
  +fechaReserva: DateTime
  +estado: String
}

class Ubicacion {
  +latitud: Double
  +longitud: Double
  +referencia: String
}

Ruta "1" o-- "0..*" Viaje
Viaje "1" o-- "1" DetalleViaje
Viaje "1" o-- "0..*" ReservaViaje
Ruta "1" o-- "1" Ubicacion
FiltroViaje ..> Ruta : filtra
@enduml