@startuml
skinparam handwritten false
skinparam monochrome false
skinparam packageStyle rect
skinparam shadowing false

title Bounded Context: Gestión de Usuarios

package "Agregado Usuario" <<Rectangle>> {
    class Usuario << (E,#FF7700) Aggregate Root >> {
        - id: UsuarioId
        - nombre: NombreCompleto
        - correo: CorreoInstitucional
        - telefono: NumeroTelefono
        + actualizarPerfil(biografia: String, foto: String)
        + validarCredencial()
    }

    class UsuarioId << (V,#99FF99) Value Object >> {
        - valor: Long
    }

    class NombreCompleto << (V,#99FF99) Value Object >> {
        - nombres: String
        - apellidos: String
    }

    class CorreoInstitucional << (V,#99FF99) Value Object >> {
        - valor: String
    }

    class NumeroTelefono << (V,#99FF99) Value Object >> {
        - valor: String
    }

    class Perfil << (E,#1199FF) Entity >> {
        - id: PerfilId
        - biografia: String
        - fotoPerfil: String
        + modificarDatos(biografia: String, foto: String)
    }

    class PerfilId << (V,#99FF99) Value Object >> {
        - valor: Long
    }

    class CredencialInstitucional << (E,#1199FF) Entity >> {
        - id: CredencialId
        - validada: Boolean
        + marcarComoValidada()
    }

    class CredencialId << (V,#99FF99) Value Object >> {
        - valor: Long
    }
}

' Relaciones estructurales del Agregado
Usuario "1" *--> "1" Perfil : posee >
Usuario "1" *--> "1" CredencialInstitucional : verifica >

@enduml