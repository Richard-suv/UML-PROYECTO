@startuml
skinparam handwritten false
skinparam monochrome false
skinparam packageStyle rect
skinparam shadowing false

title Bounded Context: Comunicación

package "Compartido" <<Rectangle>> {
    class UsuarioId << (V,#99FF99) Value Object >> {
        - valor: Long
    }
    class ViajeId << (V,#99FF99) Value Object >> {
        - valor: Long
    }
}

package "Agregado Chat" <<Rectangle>> {
    class Chat << (E,#FF7700) Aggregate Root >> {
        - id: ChatId
        - viajeId: ViajeId
        + enviarMensaje(remitenteId: UsuarioId, contenido: ContenidoMensaje)
        + generarNotificacion(tipo: String)
    }

    class ChatId << (V,#99FF99) Value Object >> {
        - valor: Long
    }

    class Mensaje << (E,#1199FF) Entity >> {
        - id: MensajeId
        - remitenteId: UsuarioId
        - contenido: ContenidoMensaje
    }

    class MensajeId << (V,#99FF99) Value Object >> {
        - valor: Long
    }

    class ContenidoMensaje << (V,#99FF99) Value Object >> {
        - valor: String
    }

    class Notificacion << (E,#1199FF) Entity >> {
        - id: NotificacionId
        - tipo: String
    }

    class NotificacionId << (V,#99FF99) Value Object >> {
        - valor: Long
    }
}

' Relaciones de Composición internas del Agregado
Chat "1" *--> "1..*" Mensaje : administra >
Chat "1" *--> "*" Notificacion : dispara >

' Relaciones por ID hacia el exterior (Contextos Compartidos)
Chat ..> ViajeId : asociado a >
Mensaje ..> UsuarioId : enviado por >
Notificacion ..> UsuarioId : destinataria >
@enduml