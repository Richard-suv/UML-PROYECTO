@startuml

title Diagrama de Base de Datos - RutaFlex

entity usuario {
  * id_usuario : UUID
  --
  nombres : varchar
  apellidos : varchar
  correo_institucional : varchar
  telefono : varchar
  estado : varchar
}

entity perfil {
  * id_perfil : UUID
  --
  id_usuario : UUID <<FK>>
  foto : varchar
  bio : text
  universidad : varchar
}

entity credencial_institucional {
  * id_credencial : UUID
  --
  id_usuario : UUID <<FK>>
  dominio : varchar
  validada : boolean
  fecha_validacion : datetime
}

entity ruta {
  * id_ruta : UUID
  --
  id_conductor : UUID <<FK>>
  origen : varchar
  destino : varchar
  hora_salida : datetime
  precio_compartido : decimal
  cupos_disponibles : int
  estado : varchar
}

entity viaje {
  * id_viaje : UUID
  --
  id_ruta : UUID <<FK>>
  fecha : date
  hora : time
  estado : varchar
}

entity detalle_viaje {
  * id_detalle : UUID
  --
  id_viaje : UUID <<FK>>
  punto_encuentro : varchar
  descripcion : text
}

entity chat {
  * id_chat : UUID
  --
  id_viaje : UUID <<FK>>
  estado : varchar
  fecha_creacion : datetime
}

entity mensaje {
  * id_mensaje : UUID
  --
  id_chat : UUID <<FK>>
  id_usuario : UUID <<FK>>
  contenido : text
  fecha_envio : datetime
  leido : boolean
}

entity calificacion {
  * id_calificacion : UUID
  --
  id_viaje : UUID <<FK>>
  id_emisor : UUID <<FK>>
  id_receptor : UUID <<FK>>
  puntaje : int
  comentario : text
  fecha : datetime
}

entity historial_viaje {
  * id_historial : UUID
  --
  id_usuario : UUID <<FK>>
  id_viaje : UUID <<FK>>
  fecha_registro : datetime
  descripcion : text
}

entity ahorro {
  * id_ahorro : UUID
  --
  id_historial : UUID <<FK>>
  monto : decimal
  moneda : varchar
}

entity co2_ahorrado {
  * id_co2 : UUID
  --
  id_historial : UUID <<FK>>
  valor : decimal
  unidad : varchar
}

usuario ||--|| perfil
usuario ||--|| credencial_institucional
usuario ||--o{ ruta : conduce
ruta ||--o{ viaje
viaje ||--|| detalle_viaje
viaje ||--o{ chat
chat ||--o{ mensaje
usuario ||--o{ mensaje
viaje ||--o{ calificacion
usuario ||--o{ calificacion : emite
usuario ||--o{ calificacion : recibe
usuario ||--o{ historial_viaje
viaje ||--o{ historial_viaje
historial_viaje ||--o{ ahorro
historial_viaje ||--o{ co2_ahorrado
@enduml